DERP_DATA_DIR=/data
DERP_CHOWN_DATA=true
DERP_TLS_MODE=ip
DERP_HOST=203.0.113.10
DERP_ADDR=:443
DERP_KEY_FILE=/data/derper.key
DERP_DERP=true
DERP_STUN=true
DERP_STUN_PORT=3478
DERP_HTTP_PORT=-1
DERP_HOME=blank
DERP_CERT_DIR=/data/certs
DERP_VERIFY_CLIENTS=false
DERP_VERIFY_CLIENT_URL=
DERP_VERIFY_CLIENT_URL_FAIL_OPEN=false
DERP_SOCKET=

# dns01 模式才需要
DERP_DNS_PROVIDER=cloudflare
DERP_ACME_EMAIL=ops@example.com
DERP_ACME_PATH=/data/acme
DERP_ACME_STAGING=false
DERP_RENEWAL_INTERVAL=43200

# 按 provider 传入 lego 所需环境变量，例如：
# CLOUDFLARE_DNS_API_TOKEN=xxxx
